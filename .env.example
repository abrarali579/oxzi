# OXZI — Environment Variables

# Database (SQLite for development)
DATABASE_URL="file:./prisma/oxzi.db"

# Authentication (change this to a secure random string in production)
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Application URL (used for links and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional — leave blank for free-tier-only operation)
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
